{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Rehearse Engine: Desktop",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "program": "${workspaceFolder}/dist-electron/electron/main.js",
      "env": {
        "VITE_DEV_SERVER_URL": "http://localhost:5180"
      },
      "preLaunchTask": "Rehearse Engine: Desktop Prereqs",
      "outFiles": [
        "${workspaceFolder}/dist-electron/**/*.js"
      ],
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal",
      "outputCapture": "std",
      "presentation": {
        "group": "rehearse-engine",
        "order": 1
      }
    },
    {
      "name": "Rehearse Engine: Web",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "Rehearse Engine: Web",
      "url": "http://localhost:5180",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "presentation": {
        "group": "rehearse-engine",
        "order": 2
      }
    },
    {
      "name": "Rehearse Engine: Web (No Task)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5180",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Rehearse Engine: Full Dev",
      "configurations": [
        "Rehearse Engine: Desktop",
        "Rehearse Engine: Web (No Task)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "rehearse-engine",
        "order": 3
      }
    }
  ]
}
